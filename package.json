{
  "name": "pc-database",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "package": "svelte-kit package",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "format_check": "prettier --check .",
    "lint": "eslint .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run && npm run test:e2e",
    "test:e2e": "docker compose -f docker-compose.test.yaml up --build --abort-on-container-exit",
    "upload_paths": "DOTENV_CONFIG_PATH=./.env.local tsx -r dotenv/config utils/populatePathFiles.ts",
    "populate_saves": "DOTENV_CONFIG_PATH=./.env.local tsx -r dotenv/config utils/populateSaves.ts",
    "populate_minimals": "DOTENV_CONFIG_PATH=./.env.local tsx -r dotenv/config utils/populateMinimals.ts",
    "add_setups": "DOTENV_CONFIG_PATH=./.env.local tsx -r dotenv/config utils/addSetups.ts"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-auto": "^6.1.1",
    "@sveltejs/adapter-vercel": "^6.3.4",
    "@sveltejs/kit": "^2.69.3",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@types/gif-encoder": "^0.7.4",
    "@types/lzma-native": "^4.0.4",
    "@types/node": "^25.9.5",
    "@types/pngjs": "^6.0.5",
    "@types/yargs": "^17.0.35",
    "csv-writer": "^1.6.0",
    "daisyui": "^5.6.18",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "mdsvex": "^0.12.7",
    "mitata": "^1.0.34",
    "prettier": "^3.9.5",
    "prettier-plugin-sql": "^0.19.2",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "svelte": "^5.56.5",
    "svelte-check": "^4.7.2",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.7",
    "yargs": "^17.7.3"
  },
  "dependencies": {
    "@inlang/paraglide-js": "^2.22.0",
    "@lucide/svelte": "^0.511.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.110.5",
    "@svar-ui/svelte-grid": "^2.7.1",
    "badge-maker": "^5.0.2",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.8.1",
    "gif-encoder": "^0.7.2",
    "glue-fumen": "^1.0.2",
    "lzma-native": "^8.0.6",
    "pngjs": "^7.0.0",
    "svelte-sonner": "^1.1.1",
    "tetris-fumen": "^1.1.3"
  }
}
